# Hammurabi configuration
# Search order: ./hammurabi.toml, then ~/.config/hammurabi/hammurabi.toml
# Environment variables override with HAMMURABI_ prefix (e.g., HAMMURABI_POLL_INTERVAL=30)

# GitHub repository to monitor (required)
repo = "owner/repo"

# Seconds between poll cycles (default: 60)
# poll_interval = 60

# Maximum parallel AI agent invocations (default: 3)
# max_concurrent_agents = 3

# GitHub label that opts issues into daemon tracking (default: "hammurabi")
# tracking_label = "hammurabi"

# Days before a blocking state gets a reminder comment (default: 7)
# stale_timeout_days = 7

# Consecutive GitHub API failures before transitioning to Failed (default: 3)
# api_retry_count = 3

# Default AI model for all tasks (required)
ai_model = "claude-sonnet-4-6"

# Default max conversation turns per AI invocation (default: 50)
# ai_max_turns = 50

# Default effort level for AI reasoning depth (default: "high")
# Options: "low", "medium", "high", "max"
# ai_effort = "high"

# GitHub usernames authorized to approve (required)
approvers = ["your-github-username"]

# Label that enables bypass mode (optional, disabled by default)
# When present and the issue creator is in the approvers list,
# the spec approval gate is skipped automatically.
# bypass_label = "hammurabi-bypass"

# GitHub authentication token (falls back to GITHUB_TOKEN env var)
# github_token = "ghp_..."

# GitHub App authentication (alternative to github_token)
# Acts as a bot with [bot] badge on PRs and comments.
# Do NOT set both github_token and [github_app].
#
# [github_app]
# app_id = 123456
# private_key_path = "/path/to/your-app.private-key.pem"
# installation_id = 78901234

# Per-task AI overrides (optional)
# [spec]
# ai_model = "claude-opus-4-6"
# ai_max_turns = 100
# ai_effort = "high"

# [decompose]
# ai_model = "claude-sonnet-4-6"
# ai_max_turns = 30
# ai_effort = "high"

# [implement]
# ai_model = "claude-sonnet-4-6"
# ai_max_turns = 50
# ai_effort = "high"

# ---------------------------------------------------------------------------
# Agent selection (ACP)
# ---------------------------------------------------------------------------
#
# By default Hammurabi drives the Claude CLI directly (`agent_kind =
# "claude-cli"`). Alternatively, you can route tasks through the Agent Client
# Protocol (ACP) and run Gemini or Codex instead of — or alongside — Claude.
#
# Available kinds:
#   claude-cli  -- default; `claude --print --output-format stream-json ...`
#   acp-claude  -- ACP via `claude-agent-acp` (npm)
#   acp-gemini  -- ACP via `gemini --acp` (native)
#   acp-codex   -- ACP via `codex-acp` (npm)
#
# Install hints (only needed for the kinds you actually use):
#   acp-claude  -- npm i -g @agentclientprotocol/claude-agent-acp @anthropic-ai/claude-code
#                  export CLAUDE_CODE_EXECUTABLE=$(which claude)
#   acp-gemini  -- npm i -g @google/gemini-cli
#   acp-codex   -- npm i -g @zed-industries/codex-acp @openai/codex
#
# Global default (applies to all repos unless overridden):
# agent_kind = "acp-claude"
#
# Per-repo override:
# [[repos]]
# repo = "owner/repo"
# agent_kind = "acp-gemini"
#
# Per-task override (falls back to per-repo, then global, then claude-cli):
# [spec]
# agent_kind = "acp-gemini"
#
# [implement]
# agent_kind = "acp-claude"
#
# [review]
# agent_kind = "acp-codex"
#
# Override the subprocess invocation for a given ACP kind (optional — every
# field is optional and falls back to the built-in default command/args):
#
# [agents.acp_claude]
# command = "claude-agent-acp"
# args = []
# env = { CLAUDE_CODE_EXECUTABLE = "/usr/local/bin/claude" }
#
# [agents.acp_gemini]
# command = "gemini"
# args = ["--acp"]
# env = { GEMINI_API_KEY = "${GEMINI_API_KEY}" }
#
# [agents.acp_codex]
# command = "codex-acp"
# args = []
#
# Notes:
#   - `max_turns` and `ai_effort` are Claude-specific; ACP kinds ignore them.
#   - ACP runs stream tool-call progress back as a live GitHub comment on the
#     issue, collapsed under <details> once the run finishes.
#   - Hammurabi auto-approves every `session/request_permission` the agent
#     emits, matching the existing `--dangerously-skip-permissions` posture.

# ---------------------------------------------------------------------------
# Alternative intake sources (Discord, ...)
# ---------------------------------------------------------------------------
#
# A `[[sources]]` entry lets Hammurabi accept ideas from a chat platform in
# addition to the GitHub issue label. Each source points at a configured
# `[[repos]]` entry by `repo = "owner/name"`; a confirmed spec is opened as
# a GitHub issue on that repo, then flows through the existing pipeline.
#
# Discord lifecycle:
#   1. User @mentions the bot in an allowlisted channel with an idea.
#   2. Hammurabi opens a Discord thread and drafts a spec into it.
#   3. User iterates with `/revise <text>` or approves with `/confirm`.
#   4. On `/confirm`, Hammurabi opens a GitHub issue carrying the spec
#      (the existing Implementing/Reviewing pipeline takes over).
#   5. `/cancel` marks the intake Failed (audit record retained).
#
# [[sources]]
# kind = "discord"
# name = "hammurabi-intake"                 # label used in logs (optional)
# channel_id = "1234567890"                 # Discord channel snowflake (as string)
# repo = "owner/hammurabi"                  # must match a [[repos]] entry
# bot_token = "${DISCORD_BOT_TOKEN}"        # env-expanded; never inline the token
# approvers = ["hydai"]                     # Discord usernames who may /confirm
# agent_kind = "acp-claude"                 # optional per-source override
# command_prefix = "/"                      # default "/"
# max_draft_revisions = 5                   # safety cap on /revise iterations
#
# Access control (pick one; setting both is an error):
# allow_users = ["hydai", "teammate"]       # explicit allowlist
# # allow_all_users = true                  # wildcard
#
# NOTE: the Discord runtime is feature-gated behind the `discord` Cargo
# feature:
#
#     cargo build --release --features discord
#     cargo run  --release --features discord watch
#
# Without that feature the daemon still compiles and every other intake
# path (GitHub label polling) works as before; Discord sources log a
# warning and are skipped. The shipped runtime uses HTTP polling on each
# poll tick; a real-time Gateway listener is a future upgrade that slots
# into the same `DiscordClient` trait without breaking the config shape.
